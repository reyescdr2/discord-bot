{
  "name": "cdr-discord-bot",
  "version": "1.1.0",
  "description": "CDR Discord Bot - Malandro Edition",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "deploy": "node deploy-commands.js",
    "postinstall": "node -e \"if (process.platform === 'linux') { require('child_process').execSync('curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o yt-dlp && chmod a+rx yt-dlp', {stdio: 'inherit'}) }\""
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@distube/ytdl-core": "^4.16.12",
    "@thatapicompany/thecatapi": "^1.0.2",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.4.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.2.0",
    "jikan4.js": "^1.5.9",
    "kazagumo": "^3.4.3",
    "libsodium-wrappers": "^0.8.2",
    "mathjs": "^15.1.1",
    "moment": "^2.29.4",
    "mongoose": "^7.6.1",
    "ms": "^2.1.3",
    "opusscript": "^0.0.8",
    "play-dl": "^1.9.7",
    "shoukaku": "^4.3.0",
    "steamapi": "^2.4.2",
    "yt-dlp-exec": "^1.0.1",
    "yt-search": "^2.13.1"
  }
}
